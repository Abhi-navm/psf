# RunPod Deployment Dockerfile
# Combines all services into a single container for RunPod GPU pods

FROM nvidia/cuda:12.1.1-cudnn8-runtime-ubuntu22.04

# Set environment variables
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    NODE_VERSION=20

# GPU and ML environment variables
ENV TF_FORCE_GPU_ALLOW_GROWTH=true \
    TF_CPP_MIN_LOG_LEVEL=2 \
    CUDA_VISIBLE_DEVICES=0 \
    WHISPER_DEVICE=cuda \
    WHISPER_MODEL=large-v3 \
    EMBEDDING_DEVICE=cuda \
    DEEPFACE_DEVICE=cuda \
    HF_HUB_OFFLINE=1 \
    TRANSFORMERS_OFFLINE=1

# Production defaults
ENV ENVIRONMENT=production \
    DEBUG=false \
    REDIS_URL=redis://localhost:6379/0 \
    CELERY_BROKER_URL=redis://localhost:6379/0 \
    CELERY_RESULT_BACKEND=redis://localhost:6379/0 \
    DATABASE_URL=sqlite+aiosqlite:///./data/sales_analyzer.db \
    OLLAMA_BASE_URL=http://localhost:11434 \
    NEXT_PUBLIC_API_URL=http://localhost:8000

WORKDIR /app

# Install system dependencies (single layer)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3.11-venv \
    python3.11-dev \
    python3-pip \
    ffmpeg \
    libsm6 \
    libxext6 \
    libgl1-mesa-glx \
    libglib2.0-0 \
    redis-server \
    curl \
    git \
    supervisor \
    nginx \
    zstd \
    && curl -fsSL https://deb.nodesource.com/setup_${NODE_VERSION}.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && curl -fsSL https://ollama.com/install.sh | sh \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Create virtual environment
RUN python3.11 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Upgrade pip and pin setuptools (>=82 breaks ctranslate2/faster-whisper)
RUN pip install --upgrade pip && pip install "setuptools<82"

# Install PyTorch with CUDA support FIRST
RUN pip install --no-cache-dir torch torchaudio --index-url https://download.pytorch.org/whl/cu121

# Copy and install backend requirements
COPY backend/requirements.txt /app/backend/requirements.txt
RUN pip install --no-cache-dir -r /app/backend/requirements.txt

# Pre-download ML models into the image so first request is fast
RUN python3.11 -c "\
from faster_whisper import WhisperModel; \
WhisperModel('large-v3', device='cpu', compute_type='int8'); \
print('Whisper large-v3 cached')" \
    && python3.11 -c "\
from sentence_transformers import SentenceTransformer; \
SentenceTransformer('all-MiniLM-L6-v2'); \
print('SentenceTransformer cached')" \
    && python3.11 -c "\
from deepface import DeepFace; \
DeepFace.analyze(img_path='https://raw.githubusercontent.com/serengil/deepface/master/tests/dataset/img1.jpg', actions=['emotion'], enforce_detection=False, silent=True); \
print('DeepFace models cached')" || true

# Copy frontend package files and install deps
COPY frontend/package*.json /app/frontend/
WORKDIR /app/frontend
RUN npm ci

# Copy application code
WORKDIR /app
COPY backend /app/backend
COPY frontend /app/frontend

# Build frontend (production)
WORKDIR /app/frontend
RUN npm run build

# Create data directories
RUN mkdir -p /app/backend/data/uploads/videos \
             /app/backend/data/uploads/temp \
             /app/backend/data/uploads/golden_pitch_decks \
             /app/backend/data/uploads/analyses \
             /app/backend/logs \
             /app/models \
             /var/log/supervisor

WORKDIR /app/backend

# Copy startup and config files
COPY runpod/supervisord.conf /etc/supervisor/conf.d/supervisord.conf
COPY runpod/nginx.conf /etc/nginx/sites-available/default
COPY runpod/start.sh /app/start.sh
RUN chmod +x /app/start.sh

# Expose ports: 80 (nginx), 8000 (API), 11434 (Ollama)
EXPOSE 80 8000 11434

WORKDIR /app

HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=5 \
    CMD curl -f http://localhost:80/ || exit 1

CMD ["/app/start.sh"]
