# Environment
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database (PostgreSQL recommended for 50+ parallel analyses)
DATABASE_URL=postgresql+asyncpg://app:pitch-analyzer-secret@localhost:5432/sales_analyzer
SYNC_DATABASE_URL=postgresql+psycopg2://app:pitch-analyzer-secret@localhost:5432/sales_analyzer
# For SQLite (dev only, no concurrent writes):
# DATABASE_URL=sqlite+aiosqlite:///./data/sales_analyzer.db
# SYNC_DATABASE_URL=sqlite:///./data/sales_analyzer.db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data/uploads
# For Cloudflare R2:
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_BUCKET_NAME=sales-pitch-videos

# AI Models
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# Analysis Settings
MAX_VIDEO_DURATION_SECONDS=600
MAX_VIDEO_SIZE_MB=500
ANALYSIS_CHUNK_DURATION=30

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
