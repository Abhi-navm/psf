# RunPod Environment Variables
# Copy this to .env and configure for your deployment

# Application
ENVIRONMENT=production
DEBUG=false

# Redis (internal)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/sales_analyzer.db

# Ollama LLM (internal)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# AI Model Settings - ALL ON GPU
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
EMBEDDING_DEVICE=cuda
DEEPFACE_DEVICE=cuda

# Analysis Performance Settings
FRAME_EXTRACTION_FPS=0.3
MAX_VIDEO_DURATION_SECONDS=1800
MAX_VIDEO_SIZE_MB=1000

# Webhook Settings (optional)
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://your-webhook-endpoint.com/analysis-complete
WEBHOOK_TIMEOUT=30

# Frontend API URL (set this to your RunPod public URL)
# Example: https://your-pod-id-8000.proxy.runpod.net
NEXT_PUBLIC_API_URL=http://localhost:8000

# RunPod specific (set automatically by RunPod)
# RUNPOD_POD_ID=
# RUNPOD_PUBLIC_IP=
